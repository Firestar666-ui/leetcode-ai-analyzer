{
  "manifest_version": 3,
  "name": "LeetCode AI 代码分析器",
  "version": "1.0.0",
  "description": "在 LeetCode 提交通过页面注入 AI 代码分析，支持方法、运行效率、代码风格三维度分析",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LeetCode AI 分析器"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.cn/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "webNavigation",
    "notifications"
  ],
  "host_permissions": [
    "https://leetcode.cn/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://leetcode.cn/*"]
    }
  ]
}
